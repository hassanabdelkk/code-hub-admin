# Caddyfile für Server 1 (Landings).
# - akzeptiert JEDE Domain (Catch-All :443)
# - on_demand_tls fragt vorher den Bun-Renderer, ob die Domain bekannt ist
#   (verhindert Cert-Spam)
# - reverse-proxied auf 127.0.0.1:3001

{
	email {$ACME_EMAIL}

	on_demand_tls {
		ask http://127.0.0.1:3001/_internal/ask
		interval 2m
		burst    5
	}
}

# HTTP → HTTPS Redirect für alle Domains
http:// {
	redir https://{host}{uri} 308
}

# HTTPS Catch-All
https:// {
	tls {
		on_demand
	}
	encode zstd gzip
	reverse_proxy 127.0.0.1:3001 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
