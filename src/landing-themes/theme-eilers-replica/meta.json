{
  "id": "theme-eilers-replica",
  "name": "Eilers Replica",
  "slug": "eilers-replica",
  "version": "4.1.0",
  "description": "Premium Unternehmensberatung-Layout — Cream/Navy/Kupfer, Playfair + Inter. Hero 2-Spalten mit Floating Card, KPI-Band, 4-Phasen-Block, 5 Leistungs-Tabs, Branchen-Liste. 1:1 Nachbau von eilers-gmbh.com — Texte/Bilder/Logo sind über Slots austauschbar.",
  "preview": "assets/preview.jpg",
  "font_pair": { "serif": "Playfair Display", "sans": "Inter" },
  "slots": [
    { "key": "seo_title",             "label": "SEO-Titel",                        "type": "text",     "default": "Eilers GmbH — Unternehmensberatung Kiel" },
    { "key": "seo_description",       "label": "Meta-Beschreibung",                "type": "textarea", "default": "Die Eilers GmbH begleitet Unternehmen bei betriebswirtschaftlichen und strategischen Weichenstellungen — Strategie, Organisation, Umsetzung. Eigentümergeführt aus Kiel." },
    { "key": "logo_text",             "label": "Logo-Text (Wortmarke)",            "type": "text",     "default": "EILERS" },
    { "key": "logo_image",            "label": "Logo (optional, ersetzt Wortmarke + Icon)", "type": "image", "default": "" },
    { "key": "firmenname",            "label": "Firmenname",                       "type": "text",     "default": "Eilers GmbH" },
    { "key": "gruendungsjahr",        "label": "Gründungsjahr",                    "type": "text",     "default": "2023" },
    { "key": "sitz_stadt",            "label": "Sitz (Stadt)",                     "type": "text",     "default": "Kiel" },
