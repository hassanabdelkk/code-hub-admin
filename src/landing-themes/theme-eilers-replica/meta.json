    { "key": "hero_subtext",          "label": "Hero-Lede-Text",                   "type": "textarea", "default": "Die Eilers GmbH begleitet Unternehmen bei betriebswirtschaftlichen und strategischen Weichenstellungen — von der Strategie über Organisation und Prozesse bis zur Umsetzung im Alltag. Eigentümergeführt aus Kiel." },

    { "key": "about_text_1",          "label": "Haltung Absatz 1",                 "type": "textarea", "default": "Wir glauben nicht an Standard-Frameworks oder austauschbare PowerPoint-Decks. Jedes Mandat beginnt mit einer ergebnisoffenen Diagnose — und endet erst, wenn die Entscheidung umgesetzt ist." },
    { "key": "about_text_2",          "label": "Haltung Absatz 2",                 "type": "textarea", "default": "Als eigentümergeführte Beratung tragen wir persönliche Verantwortung für jedes Projekt — von der ersten Hypothese bis zur Operationalisierung beim Mandanten. Kurze Wege, klare Ansprache, keine anonymen Großstrukturen." },

    { "key": "svc1_title",  "label": "Service 1 Titel",        "type": "text",     "default": "Strategieentwicklung" },
    { "key": "svc1_tag",    "label": "Service 1 Tag",          "type": "text",     "default": "STRATEGY" },
    { "key": "svc1_desc",   "label": "Service 1 Beschreibung", "type": "textarea", "default": "Von der Vision zur belastbaren Roadmap. Wir entwickeln Wachstums-, Portfolio- und Wettbewerbsstrategien für Familienunternehmen und mittelständische Konzerne." },
    { "key": "svc1_bullet1","label": "Service 1 Bullet 1",     "type": "text",     "default": "Wettbewerbs- und Marktanalysen" },
    { "key": "svc1_bullet2","label": "Service 1 Bullet 2",     "type": "text",     "default": "Portfolio-Strategie & Geschäftsmodell-Innovation" },
    { "key": "svc1_bullet3","label": "Service 1 Bullet 3",     "type": "text",     "default": "Internationalisierung" },
    { "key": "svc1_bullet4","label": "Service 1 Bullet 4",     "type": "text",     "default": "Strategie-Operationalisierung" },
    { "key": "svc1_image",  "label": "Service 1 Bild",         "type": "image",    "default": "assets/strategy-meeting.jpg" },

    { "key": "svc2_title",  "label": "Service 2 Titel",        "type": "text",     "default": "Wachstum & Partnerschaften" },
    { "key": "svc2_tag",    "label": "Service 2 Tag",          "type": "text",     "default": "GROWTH" },
    { "key": "svc2_desc",   "label": "Service 2 Beschreibung", "type": "textarea", "default": "Organisches Wachstum, M&A und strategische Allianzen — fundiert vorbereitet, sauber integriert." },
    { "key": "svc2_bullet1","label": "Service 2 Bullet 1",     "type": "text",     "default": "Wachstumsstrategie und Markteintritte" },
