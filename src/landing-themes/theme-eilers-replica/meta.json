    { "key": "svc5_desc",   "label": "Service 5 Beschreibung", "type": "textarea", "default": "Veränderung gelingt, wenn Menschen sie mitgestalten. Wir begleiten Transformationen organisatorisch und menschlich." },
    { "key": "svc5_bullet1","label": "Service 5 Bullet 1",     "type": "text",     "default": "Change Management" },
