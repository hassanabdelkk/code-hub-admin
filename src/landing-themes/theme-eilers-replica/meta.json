    { "key": "svc3_image",  "label": "Service 3 Bild",         "type": "image",    "default": "assets/digital-transform.jpg" },

    { "key": "svc4_title",  "label": "Service 4 Titel",        "type": "text",     "default": "Operative Exzellenz" },
