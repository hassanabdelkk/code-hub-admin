    { "key": "svc3_desc",   "label": "Service 3 Beschreibung", "type": "textarea", "default": "Digitalisierung mit Fokus auf das, was wirklich Wert schafft — und Menschen, die den Wandel tragen." },
    { "key": "svc3_bullet1","label": "Service 3 Bullet 1",     "type": "text",     "default": "Digitale Geschäftsmodelle" },
    { "key": "svc3_bullet2","label": "Service 3 Bullet 2",     "type": "text",     "default": "Prozessdigitalisierung und Automatisierung" },
    { "key": "svc3_bullet3","label": "Service 3 Bullet 3",     "type": "text",     "default": "Daten- und KI-Strategie" },
