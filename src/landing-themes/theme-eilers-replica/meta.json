    { "key": "svc5_bullet3","label": "Service 5 Bullet 3",     "type": "text",     "default": "Programm- und Projektsteuerung" },
    { "key": "svc5_bullet4","label": "Service 5 Bullet 4",     "type": "text",     "default": "Sparring für Geschäftsleitung und Gesellschafter" },
    { "key": "svc5_image",  "label": "Service 5 Bild",         "type": "image",    "default": "assets/change-management.jpg" },

    { "key": "cta_subtext",       "label": "CTA-Untertext",            "type": "textarea", "default": "45 Minuten, persönlich, unverbindlich. Sie erhalten eine erste fundierte Einschätzung — wir entscheiden gemeinsam, ob eine Zusammenarbeit Sinn ergibt." },
    { "key": "cta_url",           "label": "CTA Button URL",           "type": "text",     "default": "/bewerbung" },
