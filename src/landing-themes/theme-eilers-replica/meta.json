    { "key": "hrb_nummer",            "label": "HRB-Nummer",                       "type": "text",     "default": "HRB 25516 KI" },

    { "key": "hero_eyebrow",          "label": "Hero Eyebrow",                     "type": "text",     "default": "Unternehmensberatung — Kiel, seit 2023" },
    { "key": "hero_headline_pre",     "label": "Hero Headline (Zeile 1)",          "type": "text",     "default": "Entscheidungen," },
