{
  "id": "theme-qa-grid",
  "name": "QA Grid (Dark Ops)",
  "slug": "qa-grid",
  "version": "1.0.0",
  "description": "Dark-Mode Bento-Grid Landing für App/Web-QA-Tester. Neon-Mint-Akzente, Mono-Font für Zahlen, technischer Ops-Dashboard-Look.",
  "font_pair": { "sans": "Inter", "display": "Inter", "mono": "JetBrains Mono" },
  "slots": [
    { "key": "seo_title",       "label": "SEO-Titel",         "type": "text",     "default": "QA-Tester (m/w/d) im Homeoffice — 100% remote" },
    { "key": "seo_description", "label": "Meta-Beschreibung", "type": "longtext", "default": "Werde Teil unseres QA-Ops-Teams. Apps und Websites unserer Kunden systematisch testen — von zuhause, flexibel und sozialversichert." },
    { "key": "logo_text",       "label": "Logo-Text",         "type": "text",     "default": "QA/GRID" },
    { "key": "firmenname",      "label": "Firmenname",        "type": "text",     "default": "QA Grid" },

    { "key": "nav_home",        "label": "Nav Home",          "type": "text",     "default": "Overview" },
    { "key": "nav_jobs",        "label": "Nav Aufgabe",       "type": "text",     "default": "Stack" },
    { "key": "nav_about",       "label": "Nav Über uns",      "type": "text",     "default": "Team" },
    { "key": "nav_salary",      "label": "Nav Vergütung",     "type": "text",     "default": "Compensation" },
    { "key": "cta_label",       "label": "CTA-Button",        "type": "text",     "default": "Deploy Application" },

    { "key": "hero_status",     "label": "Hero Statustext",   "type": "text",     "default": "SYSTEM_STATUS · HIRING · v2.4" },
    { "key": "hero_title",      "label": "Hero Headline",     "type": "text",     "default": "QA-Tester:innen für Web & Mobile. Von zuhause. Ohne Bullshit." },
    { "key": "hero_sub",        "label": "Hero Subtext",      "type": "longtext", "default": "Unser QA-Ops-Team prüft die digitalen Produkte großer Marken bevor sie live gehen. Struktur, Aufmerksamkeit, klare Berichte — das ist der Job." },
    { "key": "hero_image",      "label": "Hero Bild",         "type": "image",    "default": "/src/assets/landing-themes/qa-grid-hero.jpg" },

    { "key": "stat1_value",     "label": "Stat 1 Wert",       "type": "text",     "default": "€19–21" },
    { "key": "stat1_text",      "label": "Stat 1 Label",      "type": "text",     "default": "pro Stunde" },
    { "key": "stat2_value",     "label": "Stat 2 Wert",       "type": "text",     "default": "8–21" },
    { "key": "stat2_text",      "label": "Stat 2 Label",      "type": "text",     "default": "Uhr flexibel, Mo–So" },
    { "key": "stat3_value",     "label": "Stat 3 Wert",       "type": "text",     "default": "100%" },
    { "key": "stat3_text",      "label": "Stat 3 Label",      "type": "text",     "default": "Homeoffice, DE" },
    { "key": "stat4_value",     "label": "Stat 4 Wert",       "type": "text",     "default": "0" },
    { "key": "stat4_text",      "label": "Stat 4 Label",      "type": "text",     "default": "Vorkenntnisse nötig" },

    { "key": "about_eyebrow",   "label": "Über uns Eyebrow",  "type": "text",     "default": "// team" },
    { "key": "about_title",     "label": "Über uns Titel",    "type": "text",     "default": "Was wir tatsächlich testen" },
    { "key": "about_text",      "label": "Über uns Text",     "type": "longtext", "default": "Web-Apps, native iOS/Android, Checkout-Flows, Onboarding-Journeys. Kein Cold-Calling, keine Callcenter-Skripte. Nur echte Nutzung, dokumentiert in strukturierten Fragebögen." },

    { "key": "how_eyebrow",     "label": "Prozess Eyebrow",   "type": "text",     "default": "// pipeline" },
    { "key": "how_title",       "label": "Prozess Titel",     "type": "text",     "default": "Der Ablauf, in vier Schritten" },
    { "key": "step1_title",     "label": "Schritt 1 Titel",   "type": "text",     "default": "assign" },
    { "key": "step1_text",      "label": "Schritt 1 Text",    "type": "text",     "default": "Ein Auftrag landet im Portal. Kunde, Plattform, Zeitbudget." },
    { "key": "step2_title",     "label": "Schritt 2 Titel",   "type": "text",     "default": "execute" },
    { "key": "step2_text",      "label": "Schritt 2 Text",    "type": "text",     "default": "Du testest die App/Site wie ein echter Nutzer. Screen-Recording optional." },
    { "key": "step3_title",     "label": "Schritt 3 Titel",   "type": "text",     "default": "report" },
    { "key": "step3_text",      "label": "Schritt 3 Text",    "type": "text",     "default": "Strukturierter Fragebogen — Bugs, UX-Reibung, Handlungsempfehlung." },
    { "key": "step4_title",     "label": "Schritt 4 Titel",   "type": "text",     "default": "settle" },
    { "key": "step4_text",      "label": "Schritt 4 Text",    "type": "text",     "default": "Stunden gehen ins Zeitkonto, Auszahlung zum Monatsende." },

    { "key": "salary_eyebrow",  "label": "Vergütung Eyebrow", "type": "text",     "default": "// compensation" },
    { "key": "salary_title",    "label": "Vergütung Titel",   "type": "text",     "default": "Dein Modell" },
    { "key": "tier1_name",      "label": "Minijob Name",      "type": "text",     "default": "MINIJOB" },
    { "key": "tier1_price",     "label": "Minijob Std.",      "type": "text",     "default": "40h" },
    { "key": "tier1_b1",        "label": "Minijob V1",        "type": "text",     "default": "Steuerfrei bis 556€" },
    { "key": "tier1_b2",        "label": "Minijob V2",        "type": "text",     "default": "Voll flexibel" },
    { "key": "tier1_b3",        "label": "Minijob V3",        "type": "text",     "default": "Perfekt als Nebenjob" },
    { "key": "tier2_name",      "label": "Teilzeit Name",     "type": "text",     "default": "TEILZEIT" },
    { "key": "tier2_price",     "label": "Teilzeit Std.",     "type": "text",     "default": "120h" },
    { "key": "tier2_b1",        "label": "Teilzeit V1",       "type": "text",     "default": "Sozialversichert" },
    { "key": "tier2_b2",        "label": "Teilzeit V2",       "type": "text",     "default": "Urlaubsanspruch" },
    { "key": "tier2_b3",        "label": "Teilzeit V3",       "type": "text",     "default": "Bezahlte Einarbeitung" },
    { "key": "tier3_name",      "label": "Vollzeit Name",     "type": "text",     "default": "VOLLZEIT" },
    { "key": "tier3_price",     "label": "Vollzeit Std.",     "type": "text",     "default": "160h" },
    { "key": "tier3_b1",        "label": "Vollzeit V1",       "type": "text",     "default": "Volle Benefits" },
    { "key": "tier3_b2",        "label": "Vollzeit V2",       "type": "text",     "default": "Technik nach Probezeit" },
    { "key": "tier3_b3",        "label": "Vollzeit V3",       "type": "text",     "default": "Karrierepfad" },

    { "key": "contact_email",   "label": "Footer E-Mail",     "type": "text",     "default": "ops@qa-grid.de" },
    { "key": "contact_phone",   "label": "Footer Telefon",    "type": "text",     "default": "+49 30 12345678" },
    { "key": "impressum_url",   "label": "Impressum-URL",     "type": "text",     "default": "impressum.html" },
    { "key": "datenschutz_url", "label": "Datenschutz-URL",   "type": "text",     "default": "datenschutz.html" }
  ]
}
