{
  "id": "theme-tester-lab",
  "name": "Tester Lab (Editorial)",
  "slug": "tester-lab",
  "version": "1.0.0",
  "description": "Editorial/Magazin-Stil für App- & Webseiten-Testing im Homeoffice. Warme Erdtöne (Terracotta/Sand), Serif-Headlines, journalistische Ruhe.",
  "font_pair": { "sans": "Inter", "display": "Fraunces" },
  "slots": [
    { "key": "seo_title",       "label": "SEO-Titel",         "type": "text",     "default": "Homeoffice Tester:innen für Apps & Websites gesucht" },
    { "key": "seo_description", "label": "Meta-Beschreibung", "type": "longtext", "default": "Wir suchen aufmerksame Menschen, die Apps und Websites unserer Kunden bequem von zuhause aus testen — flexibel, sozialversichert, gut bezahlt." },
    { "key": "logo_text",       "label": "Logo-Text",         "type": "text",     "default": "Tester Lab" },
    { "key": "firmenname",      "label": "Firmenname",        "type": "text",     "default": "Tester Lab" },

    { "key": "nav_home",        "label": "Nav Home",          "type": "text",     "default": "Start" },
    { "key": "nav_jobs",        "label": "Nav Aufgabe",       "type": "text",     "default": "Was Sie tun" },
    { "key": "nav_about",       "label": "Nav Über uns",      "type": "text",     "default": "Über uns" },
    { "key": "nav_salary",      "label": "Nav Vergütung",     "type": "text",     "default": "Vergütung" },
    { "key": "cta_label",       "label": "CTA-Button",        "type": "text",     "default": "Jetzt bewerben" },

