    { "key": "tier2_name",      "label": "Teilzeit Name",     "type": "text",     "default": "Teilzeit" },
    { "key": "tier2_price",     "label": "Teilzeit Std.",     "type": "text",     "default": "120 Std/Monat" },
    { "key": "tier2_b1",        "label": "Teilzeit Vorteil 1","type": "text",     "default": "Sozialversichert" },
    { "key": "tier2_b2",        "label": "Teilzeit Vorteil 2","type": "text",     "default": "Bezahlter Urlaub" },
    { "key": "tier2_b3",        "label": "Teilzeit Vorteil 3","type": "text",     "default": "Work-Life-Balance" },
    { "key": "tier3_name",      "label": "Vollzeit Name",     "type": "text",     "default": "Vollzeit" },
    { "key": "tier3_price",     "label": "Vollzeit Std.",     "type": "text",     "default": "160 Std/Monat" },
    { "key": "tier3_b1",        "label": "Vollzeit Vorteil 1","type": "text",     "default": "Volle Sozialleistungen" },
