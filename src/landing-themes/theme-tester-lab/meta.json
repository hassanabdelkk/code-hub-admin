    { "key": "step3_title",     "label": "Schritt 3 Titel",   "type": "text",     "default": "Fragebogen ausfüllen" },
    { "key": "step3_text",      "label": "Schritt 3 Text",    "type": "text",     "default": "Ihre Beobachtungen fließen in einen strukturierten Bericht." },
    { "key": "step4_title",     "label": "Schritt 4 Titel",   "type": "text",     "default": "Vergütung erhalten" },
