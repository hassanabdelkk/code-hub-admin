    { "key": "hero_sub",        "label": "Hero Subtext",      "type": "longtext", "default": "Für unsere Kunden prüfen Sie Apps, Websites und Dienstleistungen aus Nutzersicht — mit einem Blick fürs Detail, den kein Algorithmus ersetzt." },
    { "key": "hero_image",      "label": "Hero Bild",         "type": "image",    "default": "/src/assets/landing-themes/tester-lab-hero.jpg" },
    { "key": "hero_bullet1",    "label": "Hero Bullet 1",     "type": "text",     "default": "100 % Homeoffice, Deutschland-weit" },
    { "key": "hero_bullet2",    "label": "Hero Bullet 2",     "type": "text",     "default": "8–21 Uhr, Mo–So frei einteilbar" },
    { "key": "hero_bullet3",    "label": "Hero Bullet 3",     "type": "text",     "default": "Sozialversichert, kein Freelancing" },
    { "key": "hero_bullet4",    "label": "Hero Bullet 4",     "type": "text",     "default": "Bezahlte Einarbeitung inklusive" },

    { "key": "about_eyebrow",   "label": "Über uns Eyebrow",  "type": "text",     "default": "Kapitel Eins" },
    { "key": "about_title",     "label": "Über uns Titel",    "type": "text",     "default": "Warum Menschen testen — nicht Bots" },
    { "key": "about_text",      "label": "Über uns Text",     "type": "longtext", "default": "Unsere Kunden — Banken, Versicherer, Handelsketten — vertrauen darauf, dass ihre digitalen Produkte funktionieren, bevor sie live gehen. Sie beobachten, klicken, notieren. Und liefern uns die Feldnotizen, aus denen bessere Produkte werden." },

    { "key": "how_eyebrow",     "label": "Ablauf Eyebrow",    "type": "text",     "default": "So arbeiten Sie" },
