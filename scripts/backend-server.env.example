# Konfiguration für scripts/deploy-backend.sh
# Kopieren nach scripts/backend-server.env und Werte eintragen.
# scripts/backend-server.env sollte NICHT ins Git committed werden.

# IP oder Hostname des Backend-Servers (self-hosted Supabase)
BACKEND_HOST=123.123.123.123

# SSH-User (muss docker ausführen dürfen)
BACKEND_USER=root

# Wo liegt der Supabase-Docker-Stack auf dem Server?
BACKEND_SUPABASE_DIR=/opt/supabase

# Name des Postgres-Containers (docker ps → NAMES)
BACKEND_DB_CONTAINER=supabase-db

# Name des Edge-Functions-Containers (docker ps → NAMES)
# Häufig: supabase-edge-functions   oder   supabase_functions
BACKEND_FUNCTIONS_CONTAINER=supabase-edge-functions

# Öffentliche URL zum Prüfen, ob GoTrue nach dem Deploy antwortet
BACKEND_HEALTH_URL=https://api.mb-portal.com/auth/v1/health
